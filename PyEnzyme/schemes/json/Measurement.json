{
  "$defs": {
    "AbstractSpecies": {
      "description": "This object is used to inherit basic attributes common to all species used in the data model.",
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "description": "Unique identifier of the given object.",
          "title": "Id"
        },
        "name": {
          "description": "None",
          "title": "Name",
          "type": "string"
        },
        "vessel_id": {
          "description": "None",
          "title": "Vessel Id",
          "type": "string"
        },
        "init_conc": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "None",
          "title": "Init Conc"
        },
        "constant": {
          "description": "None",
          "title": "Constant",
          "type": "boolean"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "None",
          "title": "Unit"
        },
        "uri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "None",
          "title": "Uri"
        },
        "creator_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "None",
          "title": "Creator Id"
        }
      },
      "required": [
        "name",
        "vessel_id",
        "constant"
      ],
      "title": "AbstractSpecies",
      "type": "object"
    },
    "DataTypes": {
      "enum": [
        "conc",
        "abs",
        "feed",
        "biomass",
        "conversion",
        "peak-area"
      ],
      "title": "DataTypes",
      "type": "string"
    },
    "MeasurementData": {
      "description": "This object describes a single entity of a measurement, which corresponds to one species. It also holds replicates that contain time course data.",
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "description": "Unique identifier of the given object.",
          "title": "Id"
        },
        "init_conc": {
          "description": "Initial concentration of the measurement data.",
          "title": "Init Conc",
          "type": "number"
        },
        "unit": {
          "description": "The unit of measurement data.",
          "title": "Unit",
          "type": "string"
        },
        "measurement_id": {
          "description": "Unique measurement identifier this dataset belongs to.",
          "title": "Measurement Id",
          "type": "string"
        },
        "species_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The identifier for the described reactant.",
          "title": "Species Id"
        },
        "replicates": {
          "description": "A list of replicate objects holding raw data of the measurement.",
          "items": {
            "$ref": "#/$defs/Replicate"
          },
          "multiple": true,
          "title": "Replicates",
          "type": "array"
        }
      },
      "required": [
        "init_conc",
        "unit",
        "measurement_id"
      ],
      "title": "MeasurementData",
      "type": "object"
    },
    "Replicate": {
      "description": "This object contains the measured time course data as well as metadata to the replicate itself.",
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "description": "Unique identifier of the given object.",
          "title": "Id"
        },
        "species_id": {
          "allOf": [
            {
              "$ref": "#/$defs/AbstractSpecies"
            }
          ],
          "description": "Unique identifier of the species that has been measured."
        },
        "measurement_id": {
          "description": "Unique identifier of the measurement that the replicate is part of.",
          "title": "Measurement Id",
          "type": "string"
        },
        "data_type": {
          "allOf": [
            {
              "$ref": "#/$defs/DataTypes"
            }
          ],
          "default": "conc",
          "description": "Type of data that was measured (e.g. concentration)"
        },
        "data_unit": {
          "description": "SI unit of the data that was measured.",
          "title": "Data Unit",
          "type": "string"
        },
        "time_unit": {
          "description": "Time unit of the replicate.",
          "title": "Time Unit",
          "type": "string"
        },
        "time": {
          "description": "Time steps of the replicate.",
          "items": {
            "type": "number"
          },
          "multiple": true,
          "title": "Time",
          "type": "array"
        },
        "data": {
          "description": "Data that was measured.",
          "items": {
            "type": "number"
          },
          "multiple": true,
          "title": "Data",
          "type": "array"
        },
        "is_calculated": {
          "default": false,
          "description": "Whether or not the data has been generated by simulation.",
          "title": "Is Calculated",
          "type": "boolean"
        },
        "uri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "URI of the protein.",
          "title": "Uri"
        },
        "creator_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Unique identifier of the author.",
          "title": "Creator Id"
        }
      },
      "required": [
        "species_id",
        "measurement_id",
        "data_unit",
        "time_unit"
      ],
      "title": "Replicate",
      "type": "object"
    }
  },
  "description": "This object describes the result of a measurement, which includes time course data of any type defined in DataTypes. It includes initial concentrations of all species used in a single measurement.",
  "properties": {
    "id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Unique identifier of the given object.",
      "title": "Id"
    },
    "name": {
      "description": "Name of the measurement",
      "title": "Name",
      "type": "string"
    },
    "temperature": {
      "description": "Numeric value of the temperature of the reaction.",
      "template_alias": "Temperature value",
      "title": "Temperature",
      "type": "number"
    },
    "temperature_unit": {
      "description": "Unit of the temperature of the reaction.",
      "pattern": "kelvin|Kelvin|k|K|celsius|Celsius|C|c",
      "title": "Temperature Unit",
      "type": "string"
    },
    "ph": {
      "description": "PH value of the reaction.",
      "inclusivemaximum": 14,
      "inclusiveminimum": 0,
      "title": "Ph",
      "type": "number"
    },
    "species": {
      "description": "Species of the measurement.",
      "items": {
        "$ref": "#/$defs/MeasurementData"
      },
      "multiple": true,
      "title": "Species",
      "type": "array"
    },
    "global_time": {
      "description": "Global time of the measurement all replicates agree on.",
      "items": {
        "type": "number"
      },
      "multiple": true,
      "title": "Global Time",
      "type": "array"
    },
    "global_time_unit": {
      "description": "Unit of the global time.",
      "title": "Global Time Unit",
      "type": "string"
    },
    "uri": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "URI of the reaction.",
      "title": "Uri"
    },
    "creator_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Unique identifier of the author.",
      "title": "Creator Id"
    }
  },
  "required": [
    "name",
    "temperature",
    "temperature_unit",
    "ph",
    "global_time_unit"
  ],
  "title": "Measurement",
  "type": "object"
}