        "creator_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Unique identifier of the author.",
          "title": "Creator Id"
        }
      },
      "required": [
        "species_id",
        "measurement_id",
