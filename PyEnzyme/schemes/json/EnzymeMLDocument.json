        "measurement_id": {
          "description": "Unique identifier of the measurement that the replicate is part of.",
          "title": "Measurement Id",
          "type": "string"
        },
        "data_type": {
          "allOf": [
            {
              "$ref": "#/$defs/DataTypes"
