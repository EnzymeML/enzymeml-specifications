          "multiple": true,
          "template_alias": "Products",
          "title": "Products",
          "type": "array"
        },
        "modifiers": {
          "description": "List of modifiers (proteins, inhibitors, stimulators) containing ReactionElement objects.",
          "items": {
            "$ref": "#/$defs/ReactionElement"
          },
          "multiple": true,
          "template_alias": "Modifiers",
          "title": "Modifiers",
          "type": "array"
        }
