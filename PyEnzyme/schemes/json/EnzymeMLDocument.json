          "default": null,
          "description": "None",
          "title": "Init Conc"
        },
        "constant": {
          "description": "None",
          "title": "Constant",
          "type": "boolean"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "None",
          "title": "Unit"
        },
        "uri": {
