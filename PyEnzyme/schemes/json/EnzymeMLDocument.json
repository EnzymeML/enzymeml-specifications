    "Creator": {
      "description": "The creator object contains all information about authors that contributed to the resulting document.",
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "description": "Unique identifier of the given object.",
          "title": "Id"
        },
        "given_name": {
          "description": "Given name of the author or contributor.",
          "title": "Given Name",
          "type": "string"
        },
        "family_name": {
          "description": "Family name of the author or contributor.",
          "title": "Family Name",
          "type": "string"
        },
        "mail": {
          "description": "Email address of the author or contributor.",
          "title": "Mail",
          "type": "string"
        }
      },
      "required": [
        "given_name",
        "family_name",
        "mail"
      ],
      "title": "Creator",
      "type": "object"
    },
    "DataTypes": {
      "enum": [
        "conc",
        "abs",
        "feed",
        "biomass",
        "conversion",
        "peak-area"
      ],
      "title": "DataTypes",
      "type": "string"
    },
    "File": {
      "description": "This object contains files that have been attached to the document.",
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "description": "Unique identifier of the given object.",
          "title": "Id"
        },
        "name": {
          "description": "Name of the file",
          "title": "Name",
          "type": "string"
        },
        "content": {
          "description": "Contents of the file",
          "format": "binary",
          "title": "Content",
          "type": "string"
        },
        "filetype": {
          "description": "Type of the file such as .xml, .json, and so on",
          "title": "Filetype",
          "type": "string"
        }
      },
      "required": [
        "name",
        "content",
        "filetype"
      ],
      "title": "File",
      "type": "object"
    },
    "KineticModel": {
      "description": "This object describes a kinetic model that was derived from the experiment.",
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "description": "Unique identifier of the given object.",
          "title": "Id"
        },
        "name": {
          "description": "Name of the kinetic law.",
          "title": "Name",
          "type": "string"
        },
        "equation": {
          "description": "Equation for the kinetic law.",
          "title": "Equation",
          "type": "string"
        },
        "parameters": {
          "description": "List of estimated parameters.",
          "items": {
            "$ref": "#/$defs/KineticParameter"
          },
          "multiple": true,
          "title": "Parameters",
          "type": "array"
        },
        "ontology": {
          "anyOf": [
            {
              "$ref": "#/$defs/SBOTerm"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Type of the estimated parameter."
        }
      },
      "required": [
        "name",
        "equation"
      ],
      "title": "KineticModel",
      "type": "object"
    },
    "KineticParameter": {
      "description": "This object describes the parameters of the kinetic model and can include all estimated values.",
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "description": "Unique identifier of the given object.",
          "title": "Id"
        },
        "name": {
          "description": "Name of the estimated parameter.",
          "title": "Name",
          "type": "string"
        },
        "value": {
          "description": "Numerical value of the estimated parameter.",
          "title": "Value",
          "type": "number"
        },
        "unit": {
          "description": "Unit of the estimated parameter.",
          "title": "Unit",
          "type": "string"
        },
        "initial_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Initial value that was used for the parameter estimation.",
          "title": "Initial Value"
        },
        "upper": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Upper bound of the estimated parameter.",
          "title": "Upper"
        },
        "lower": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Lower bound of the estimated parameter.",
          "title": "Lower"
        },
        "is_global": {
          "default": false,
          "description": "Specifies if this parameter is global for the entire EnzymeMLDocument.",
          "title": "Is Global",
          "type": "boolean"
        },
        "stdev": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Standard deviation of the estimated parameter.",
          "title": "Stdev"
        },
        "constant": {
          "default": false,
          "description": "Specifies if this parameter is constant",
          "title": "Constant",
          "type": "boolean"
        },
        "ontology": {
          "anyOf": [
            {
              "$ref": "#/$defs/SBOTerm"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Type of the estimated parameter."
        }
      },
      "required": [
        "name",
        "value",
        "unit"
      ],
      "title": "KineticParameter",
      "type": "object"
    },
    "Measurement": {
      "description": "This object describes the result of a measurement, which includes time course data of any type defined in DataTypes. It includes initial concentrations of all species used in a single measurement.",
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "description": "Unique identifier of the given object.",
          "title": "Id"
        },
        "name": {
          "description": "Name of the measurement",
          "title": "Name",
          "type": "string"
        },
        "temperature": {
          "description": "Numeric value of the temperature of the reaction.",
          "template_alias": "Temperature value",
          "title": "Temperature",
          "type": "number"
        },
        "temperature_unit": {
          "description": "Unit of the temperature of the reaction.",
          "pattern": "kelvin|Kelvin|k|K|celsius|Celsius|C|c",
          "title": "Temperature Unit",
          "type": "string"
        },
        "ph": {
          "description": "PH value of the reaction.",
          "inclusivemaximum": 14,
          "inclusiveminimum": 0,
          "title": "Ph",
          "type": "number"
        },
        "species": {
          "description": "Species of the measurement.",
          "items": {
            "$ref": "#/$defs/MeasurementData"
          },
          "multiple": true,
          "title": "Species",
          "type": "array"
        },
        "global_time": {
          "description": "Global time of the measurement all replicates agree on.",
          "items": {
            "type": "number"
          },
          "multiple": true,
          "title": "Global Time",
          "type": "array"
        },
        "global_time_unit": {
          "description": "Unit of the global time.",
          "title": "Global Time Unit",
          "type": "string"
        },
        "uri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "URI of the reaction.",
          "title": "Uri"
        },
        "creator_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Unique identifier of the author.",
          "title": "Creator Id"
        }
      },
      "required": [
        "name",
        "temperature",
        "temperature_unit",
        "ph",
        "global_time_unit"
      ],
      "title": "Measurement",
      "type": "object"
    },
    "MeasurementData": {
      "description": "This object describes a single entity of a measurement, which corresponds to one species. It also holds replicates that contain time course data.",
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "description": "Unique identifier of the given object.",
          "title": "Id"
        },
        "init_conc": {
          "description": "Initial concentration of the measurement data.",
          "title": "Init Conc",
          "type": "number"
        },
        "unit": {
          "description": "The unit of measurement data.",
          "title": "Unit",
          "type": "string"
        },
        "measurement_id": {
          "description": "Unique measurement identifier this dataset belongs to.",
          "title": "Measurement Id",
          "type": "string"
        },
        "species_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The identifier for the described reactant.",
          "title": "Species Id"
        },
        "replicates": {
          "description": "A list of replicate objects holding raw data of the measurement.",
          "items": {
            "$ref": "#/$defs/Replicate"
          },
          "multiple": true,
          "title": "Replicates",
          "type": "array"
        }
      },
      "required": [
        "init_conc",
        "unit",
        "measurement_id"
      ],
      "title": "MeasurementData",
      "type": "object"
    },
    "Protein": {
