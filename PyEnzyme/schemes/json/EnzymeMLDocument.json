              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "description": "Unique identifier of the given object.",
          "title": "Id"
        },
        "name": {
          "description": "None",
          "title": "Name",
          "type": "string"
        },
        "vessel_id": {
          "description": "None",
          "title": "Vessel Id",
          "type": "string"
        },
        "init_conc": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
